{
  "manifest_version": 3,
  "name": "DeepFake Video Detector",
  "description": "Analyze videos with the local DeepFake Detection Flask model.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "DeepFake Detector",
    "default_icon": {
      "128": "icon.svg"
    }
  },
  "icons": {
    "128": "icon.svg"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "notifications",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
